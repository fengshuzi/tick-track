{
  "name": "tick-track",
  "version": "1.0.1",
  "description": "Track time spent on tasks with automatic duration calculation",
  "main": "main.js",
  "scripts": {
    "lint": "eslint \"**/*.{ts,tsx}\"",
    "build": "npm run lint && node esbuild.config.mjs production",
    "dev": "node esbuild.config.mjs",
    "deploy": "npm run build && node deploy.mjs",
    "release": "node release.mjs"
  },
  "keywords": [
    "obsidian",
    "obsidian-plugin",
    "time-tracking",
    "task-management"
  ],
  "author": "lizhifeng",
  "license": "MIT",
  "devDependencies": {
    "@eslint/json": "^0.14.0",
    "@types/node": "^18.0.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@typescript-eslint/utils": "^8.58.2",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.19.0",
    "eslint": "^9.39.4",
    "eslint-plugin-obsidianmd": "^0.1.9",
    "globals": "^17.5.0",
    "obsidian": "latest",
    "tslib": "^2.6.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.2"
  }
}
